# ─────────────────────────────────────────────
# Streamlit Secrets Configuration
# ─────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml
# and fill in your actual values.
# ─────────────────────────────────────────────

# Shared password for all users (change this!)
APP_PASSWORD = "your_shared_password_here"

# Your Anthropic API key for Claude-powered parsing
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY = "sk-ant-api03-..."

# Name of the Google Sheet (will be created if it doesn't exist)
SHEET_NAME = "Expense Tracker"

# (Optional) Currency symbol — defaults to "S$"
# CURRENCY_SYMBOL = "S$"

# (Optional) Override the Claude model used for parsing
# CLAUDE_MODEL = "claude-sonnet-4-20250514"

# Google Cloud Service Account credentials
# Follow the setup guide in SETUP.md to get these
[gcp_service_account]
type = "service_account"
project_id = "your-project-id"
private_key_id = "key-id-here"
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "expense-tracker@your-project.iam.gserviceaccount.com"
client_id = "123456789"
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "https://www.googleapis.com/robot/v1/metadata/x509/expense-tracker%40your-project.iam.gserviceaccount.com"